{
  "name": "imessage-to-sqldb",
  "version": "1.0.0",
  "description": "Webhook ingestion service that stores iMessage/RCS/SMS events into PostgreSQL.",
  "main": "dist/src/server.js",
  "scripts": {
    "dev": "node --watch --import tsx src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/server.js",
    "migrate": "node --import tsx scripts/migrate.ts",
    "import:imessage": "node --import tsx scripts/import-imessages.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "webhooks",
    "postgres",
    "imessage",
    "sms",
    "rcs"
  ],
  "author": "",
  "license": "MIT",
  "type": "commonjs",
  "dependencies": {
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.4.0",
    "@types/pg": "^8.18.0",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
